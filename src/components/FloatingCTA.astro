---
import { telMobile, whatsappLink, site } from '../data/site';
import Icon from './Icon.astro';
---
<div class="floating-mobile fixed bottom-3 left-0 right-0 z-40 px-3 gap-2 pointer-events-none">
  <a href={telMobile} class="btn btn-primary pointer-events-auto flex-1 !gap-2" style="padding-top:0.85rem;padding-bottom:0.85rem;" aria-label={`Call Kensons Garage on ${site.phoneMobile}`}>
    <Icon name="Phone" size={16} strokeWidth={2.4} />
    <span class="flex flex-col items-start leading-none">
      <span class="text-[0.58rem] uppercase tracking-wider opacity-80">Call us now</span>
      <span class="text-[0.82rem] font-mono font-semibold">{site.phoneMobile}</span>
    </span>
  </a>
  <a href={whatsappLink} target="_blank" rel="noopener" class="btn btn-whatsapp pointer-events-auto !px-4" style="padding-top:0.85rem;padding-bottom:0.85rem;" aria-label="Send photos of the damage on WhatsApp">
    <Icon name="MessageCircle" size={20} strokeWidth={2.2} />
  </a>
</div>

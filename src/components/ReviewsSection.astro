---
import Icon from './Icon.astro';
import { reviews, reviewsMeta } from '../data/reviews';
interface Props { dark?: boolean; heading?: string; }
const { dark = true, heading = 'What our customers say about us' } = Astro.props;

const Star = () =>
  '<svg width="16" height="16" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>';
const stars = Array.from({ length: 5 }).map(Star).join('');
---
<section class={dark ? 'section-navy py-24 md:py-32 relative overflow-hidden' : 'section-snow py-24 md:py-32'}>
  {dark && <div class="glow-orb" style="width: 480px; height: 480px; top: 6%; left: -150px; background: #C8102E; opacity: 0.12;"></div>}
  {dark && <div class="glow-orb" style="width: 420px; height: 420px; bottom: 4%; right: -120px; background: #C9A961; opacity: 0.12;"></div>}
  <div class="container-mcp relative">
    <div class="text-center max-w-2xl mx-auto mb-14 fade-in">
      <span class="eyebrow eyebrow-center eyebrow-gold mb-5">Testimonials</span>
      <h2 class={`heading-lg text-balance mt-1 ${dark ? 'text-white' : ''}`}>{heading}</h2>
      <p class={`text-lg mt-4 text-pretty ${dark ? 'text-white/70' : 'text-muted'}`}>{reviewsMeta.intro}</p>
      <div class="inline-flex items-center gap-2.5 mt-6">
        <span class="stars" set:html={stars}></span>
        <span class={`text-sm font-semibold font-mono ${dark ? 'text-white/85' : 'text-ink'}`}>{reviewsMeta.rating} · {reviewsMeta.count} Google reviews</span>
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-6 items-stretch">
      {reviews.map((r, i) => (
        <figure class={`relative h-full flex flex-col rounded-[1.75rem] p-7 md:p-8 fade-in stagger-${i + 1} ${dark ? 'glass' : 'card'}`}>
          <Icon name="Quote" size={34} strokeWidth={1.5} class="text-gold opacity-60 mb-4" />
          <span class="stars mb-4" set:html={stars}></span>
          <blockquote class={`flex-1 text-[0.97rem] leading-relaxed text-pretty ${dark ? 'text-white/80' : 'text-muted'}`}>
            {r.quote}
          </blockquote>
          <figcaption class={`mt-6 pt-5 flex items-center gap-3 border-t ${dark ? 'border-white/12' : 'border-line'}`}>
            <span class="w-11 h-11 rounded-full flex items-center justify-center font-bold text-white flex-shrink-0" style="background: linear-gradient(180deg, #E11D38, #C8102E);" aria-hidden="true">{r.name.charAt(0)}</span>
            <span class="flex flex-col leading-tight">
              <span class={`font-bold ${dark ? 'text-white' : 'text-ink'}`}>{r.name}</span>
              <span class={`text-[0.82rem] ${dark ? 'text-white/55' : 'text-muted-light'}`}>{r.vehicle} · via Google</span>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>

    <div class="text-center mt-12 fade-in">
      <a href={reviewsMeta.url} target="_blank" rel="noopener" class={`btn ${dark ? 'btn-glass' : 'btn-navy'}`}>
        <Icon name="Star" size={16} strokeWidth={2.2} />
        Read all reviews on Google
        <Icon name="ExternalLink" size={15} strokeWidth={2.2} />
      </a>
    </div>
  </div>
</section>

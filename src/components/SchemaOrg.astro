---
import { site } from '../data/site';
import { services } from '../data/services';
import { reviews } from '../data/reviews';

interface Props { schema?: object | null; }
const { schema = null } = Astro.props;

const business = {
  '@context': 'https://schema.org',
  '@type': ['AutoBodyShop', 'AutoRepair', 'LocalBusiness'],
  '@id': site.url + '#business',
  name: site.name,
  description: site.description,
  url: site.url,
  telephone: site.phoneMobileIntl,
  email: site.email,
  image: site.url + '/images/og-image.jpg',
  logo: site.url + '/logo.png',
  priceRange: '££',
  currenciesAccepted: 'GBP',
  paymentAccepted: ['Cash', 'Debit Card', 'Credit Card', 'Bank Transfer', 'BACS'],
  slogan: site.tagline,
  address: {
    '@type': 'PostalAddress',
    streetAddress: `${site.address.unit}, ${site.address.street}`,
    addressLocality: site.address.area,
    addressRegion: site.address.region,
    postalCode: site.address.postcode,
    addressCountry: site.address.countryCode,
  },
  geo: { '@type': 'GeoCoordinates', latitude: site.address.lat, longitude: site.address.lng },
  hasMap: site.googleMapsUrl,
  sameAs: [site.social.instagram, site.social.tiktok],
  areaServed: site.areasServed.map((a) => ({ '@type': 'Place', name: a })),
  // Saturday omitted from structured hours — not stated on the original
  // site (flagged for verification in JUDGEMENT_CALLS.md).
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'], opens: '09:00', closes: '19:00' },
  ],
  knowsAbout: [
    'Car Body Repair', 'Accident Repair', 'Collision Repair', 'Car Resprays',
    'Paintless Dent Repair', 'SMART Repairs', 'Panel Replacement', 'Insurance Repairs',
    'Vehicle Servicing', 'Brake Repairs', 'Wheel Refurbishment', 'Car Customisation',
  ],
  makesOffer: services.map((s) => ({
    '@type': 'Offer',
    itemOffered: { '@type': 'Service', name: s.title, description: s.tagline },
  })),
  review: reviews.map((r) => ({
    '@type': 'Review',
    author: { '@type': 'Person', name: r.name },
    reviewRating: { '@type': 'Rating', ratingValue: r.rating, bestRating: 5, worstRating: 1 },
    reviewBody: r.quote,
  })),
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: site.rating.value,
    reviewCount: site.rating.count,
    bestRating: 5,
    worstRating: 1,
  },
};
---
<script type="application/ld+json" set:html={JSON.stringify(business)} />
{schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

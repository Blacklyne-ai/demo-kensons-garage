---
// Central Lucide icon map (@lucide/astro — named imports).
// Data files reference icons by name; every icon used site-wide is here.
import {
  Car, CarFront, Wrench, Hammer, PaintBucket, Brush, SprayCan, Palette, Paintbrush,
  Settings, Cog, Lightbulb, Layers, PanelTop, LayoutGrid,
  ShieldCheck, Award, BadgeCheck, Shield, Clock, MapPin, MapPinned,
  Truck, Search, CircleCheck, CircleDot, Check, CheckCheck,
  Handshake, FileText, FileCheck, ClipboardCheck, Camera, MessageCircle, Phone, PhoneCall, Mail, Star,
  ArrowRight, ArrowUpRight, Menu, X, ChevronRight, ChevronDown, ChevronUp,
  Navigation, ExternalLink, Building, Building2, Store, Users, UsersRound,
  Zap, Disc, Battery, Sparkles, Gauge, ThumbsUp, Tag, Package, Boxes,
  Calendar, ShoppingCart, Banknote, Wallet, Receipt, Info, Plus, Minus, Quote, HelpCircle, Heart,
} from '@lucide/astro';

const MAP: Record<string, any> = {
  Car, CarFront, Wrench, Hammer, PaintBucket, Brush, SprayCan, Palette, Paintbrush,
  Settings, Cog, Lightbulb, Layers, PanelTop, LayoutGrid,
  ShieldCheck, Award, BadgeCheck, Shield, Clock, MapPin, MapPinned,
  Truck, Search, CircleCheck, CircleDot, Check, CheckCheck,
  Handshake, FileText, FileCheck, ClipboardCheck, Camera, MessageCircle, Phone, PhoneCall, Mail, Star,
  ArrowRight, ArrowUpRight, Menu, X, ChevronRight, ChevronDown, ChevronUp,
  Navigation, ExternalLink, Building, Building2, Store, Users, UsersRound,
  Zap, Disc, Battery, Sparkles, Gauge, ThumbsUp, Tag, Package, Boxes,
  Calendar, ShoppingCart, Banknote, Wallet, Receipt, Info, Plus, Minus, Quote, HelpCircle, Heart,
};

interface Props {
  name: string;
  size?: number;
  class?: string;
  strokeWidth?: number;
}
const { name, size = 24, class: className = '', strokeWidth = 1.75 } = Astro.props;
const Cmp = MAP[name] ?? CircleDot;
---
<Cmp size={size} class={className} stroke-width={strokeWidth} />

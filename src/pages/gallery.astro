---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import PageHero from '../components/PageHero.astro';
import Faqs from '../components/Faqs.astro';
import CtaBand from '../components/CtaBand.astro';
import { whatsappLink } from '../data/site';
import { galleryIntro, galleryClosing } from '../data/content';

// 12 real Kensons photos (a clean multiple of 3 for full grid rows).
// gallery-1..7 + work-1..3 + about-5 are before/after collages (labels baked
// into the image — never overlay our own). gallery-8 is a single finished car.
const galleryImages: { src: string; alt: string }[] = [
  { src: '/images/gallery-1.jpg', alt: 'Before and after accident repair of a saloon car at Kensons Garage' },
  { src: '/images/gallery-2.jpg', alt: 'Before and after body repair and respray at Kensons Garage' },
  { src: '/images/gallery-3.jpg', alt: 'Before and after panel and paintwork restoration at Kensons Garage' },
  { src: '/images/gallery-4.jpg', alt: 'Before and after collision damage repair at Kensons Garage' },
  { src: '/images/gallery-5.jpg', alt: 'Before and after dent and scratch repair at Kensons Garage' },
  { src: '/images/gallery-6.jpg', alt: 'Before and after bumper repair and refinishing at Kensons Garage' },
  { src: '/images/gallery-7.jpg', alt: 'Before and after bodywork repair at Kensons Garage' },
  { src: '/images/work-1.jpg', alt: 'Before and after vehicle repair completed at Kensons Garage' },
  { src: '/images/work-2.jpg', alt: 'Before and after accident repair work at Kensons Garage' },
  { src: '/images/work-3.jpg', alt: 'Before and after paintwork repair at Kensons Garage' },
  { src: '/images/about-5.jpg', alt: 'Vehicle body repair in progress in the Kensons Garage workshop' },
  { src: '/images/gallery-8.jpg', alt: 'A car fully restored to its best condition by Kensons Garage' },
];
---

<Layout
  current="/gallery"
  title="Gallery - Kensons Garage | Car Body Repair South London"
  description="See real before and after car body repairs by Kensons Garage, Brixton. From minor scratches to major accident damage — this is art."
>
  <!-- ════════ HERO ════════ -->
  <PageHero
    eyebrow="Our Gallery"
    title="Making damage disappear"
    subtitle={galleryIntro}
    crumb="Gallery"
    image="/images/gallery-2.jpg"
  />

  <!-- ════════ GALLERY GRID ════════ -->
  <section class="py-24 md:py-32 bg-white">
    <div class="container-mcp">
      <div class="text-center max-w-2xl mx-auto mb-14 fade-in">
        <span class="eyebrow eyebrow-center mb-5">Real Repairs</span>
        <h2 class="heading-lg text-balance mt-1 mb-4">Before &amp; after, every time.</h2>
        <p class="text-lg text-muted text-pretty">Genuine repairs carried out under Arch 2 — restored panels, seamless paintwork and finishes made invisible.</p>
        <p class="tagline-art text-gold text-3xl md:text-4xl mt-4">This is Art.</p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {galleryImages.map((img, i) => (
          <div class={`part-card group fade-in stagger-${(i % 3) + 1}`}>
            <div class="part-media">
              <img
                src={img.src}
                alt={img.alt}
                width="900"
                height="675"
                loading="lazy"
                class="transition-transform duration-700 group-hover:scale-105"
              />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════ CLOSING BAND ════════ -->
  <section class="section-navy py-24 md:py-32 relative overflow-hidden">
    <div class="glow-orb" style="width: 440px; height: 440px; top: -130px; left: -90px; background: #C8102E; opacity: 0.16;"></div>
    <div class="glow-orb" style="width: 380px; height: 380px; bottom: -150px; right: -80px; background: #C9A961; opacity: 0.2;"></div>
    <div class="container-mcp relative">
      <div class="max-w-3xl mx-auto text-center fade-in">
        <span class="eyebrow eyebrow-gold eyebrow-center mb-5">Quality Restoration</span>
        <p class="text-xl md:text-2xl text-white/85 leading-relaxed text-pretty">{galleryClosing}</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center mt-10">
          <a href="/contact" class="btn btn-primary btn-lg">
            Get a Free Quote
            <Icon name="ArrowRight" size={16} strokeWidth={2.5} />
          </a>
          <a href={whatsappLink} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">
            <Icon name="MessageCircle" size={18} strokeWidth={2.2} />
            Send photos on WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ FAQ ════════ -->
  <section id="faq" class="py-24 md:py-32 bg-white" style="scroll-margin-top:6rem">
    <div class="container-mcp">
      <div class="text-center max-w-2xl mx-auto mb-14 fade-in">
        <span class="eyebrow eyebrow-center mb-5">FAQs</span>
        <h2 class="heading-lg text-balance mt-1 mb-4">Frequently Asked Questions</h2>
        <p class="text-lg text-muted text-pretty">Whether it is a minor scratch or major collision damage, we know you will have questions. We have answered the most frequently asked questions to help you understand our services and what to expect.</p>
      </div>
      <Faqs />
    </div>
  </section>

  <CtaBand />
</Layout>

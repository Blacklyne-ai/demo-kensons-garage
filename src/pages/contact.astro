---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import PageHero from '../components/PageHero.astro';
import QuoteForm from '../components/QuoteForm.astro';
import ContactMethods from '../components/ContactMethods.astro';
import OpeningHours from '../components/OpeningHours.astro';
import MapBlock from '../components/MapBlock.astro';
import { site, telMobile, telLandline, mailLink, whatsappLink } from '../data/site';
---

<Layout
  current="/contact"
  title="Contact Us - Kensons Garage | Car Body Repair South London"
  description="Get in touch with Kensons Garage in Brixton, South London. Call 07950 428 012, WhatsApp photos or email for a free car body repair quote."
>
  <!-- ════════ HERO ════════ -->
  <PageHero
    eyebrow="Contact Kensons Garage"
    title="Get in touch"
    subtitle="Get in touch for a quote, advice, or to book your repair."
    crumb="Contact"
    image="/images/service-3.jpg"
    primary={{ href: telMobile, label: `Call ${site.phoneMobile}` }}
    secondary={{ href: '#quote', label: 'Send photos for a quote' }}
  />

  <!-- ════════ MAIN CONTACT BLOCK ════════ -->
  <section class="py-24 md:py-32 bg-white">
    <div class="container-mcp">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-start">

        <!-- LEFT — quote form -->
        <div id="quote" class="fade-in" style="scroll-margin-top: 6rem;">
          <div class="mb-7">
            <span class="eyebrow mb-5">Request a quote</span>
            <h2 class="heading-lg text-balance mt-1">Tell us about the damage.</h2>
            <p class="text-lg text-muted mt-4 text-pretty">
              Send a few details and clear photos of the work — we'll come back to you with an honest, no-obligation estimate. <span class="tagline-art text-gold">This is Art.</span>
            </p>
          </div>
          <QuoteForm />
        </div>

        <!-- RIGHT — contact methods + opening hours -->
        <div class="fade-in stagger-1 flex flex-col gap-8">
          <div>
            <span class="eyebrow mb-5">Talk to us directly</span>
            <h2 class="heading-lg text-balance mt-1 mb-6">Call, message or email.</h2>
            <ContactMethods />
            <p class="text-[0.92rem] text-muted mt-5 flex items-center gap-2">
              <Icon name="HelpCircle" size={16} strokeWidth={2.1} class="text-orange-deep flex-shrink-0" />
              <span>Got questions? Check our <a href="/gallery#faq" class="text-orange-deep font-semibold underline underline-offset-2">FAQs</a>.</span>
            </p>
          </div>

          <OpeningHours />

          <!-- Follow us -->
          <div class="tile">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
              <div>
                <p class="text-[0.7rem] uppercase tracking-[0.14em] font-mono text-muted mb-1">Follow our work</p>
                <p class="font-bold text-ink leading-tight">See the latest repairs on social</p>
              </div>
              <div class="flex flex-wrap gap-3">
                <a href={site.social.instagram} target="_blank" rel="noopener" class="btn btn-navy btn-sm" aria-label="Follow Kensons Garage on Instagram">
                  <Icon name="Camera" size={15} strokeWidth={2.2} />
                  Instagram
                </a>
                <a href={site.social.tiktok} target="_blank" rel="noopener" class="btn btn-outline btn-sm" aria-label="Follow Kensons Garage on TikTok">
                  <Icon name="Sparkles" size={15} strokeWidth={2.2} />
                  TikTok
                </a>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ════════ FIND US / MAP ════════ -->
  <section class="py-24 md:py-32 section-snow">
    <div class="container-mcp">
      <div class="text-center max-w-2xl mx-auto mb-14 fade-in">
        <span class="eyebrow eyebrow-center mb-5">Visit the workshop</span>
        <h2 class="heading-lg text-balance mt-1">Find us under Arch 2.</h2>
        <p class="text-lg text-muted mt-4 text-pretty">Our railway-arch workshop sits on Ferndale Road in the heart of Brixton, South London — easy to reach across SW9 and beyond.</p>
      </div>
      <MapBlock />
    </div>
  </section>
</Layout>
